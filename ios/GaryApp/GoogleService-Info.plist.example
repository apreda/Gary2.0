<?xml version="1.0" encoding="UTF-8"?>
<!--
  TEMPLATE — copy to GoogleService-Info.plist and replace with real values.
  Download the real file from Firebase Console:
    https://console.firebase.google.com/ → Project Settings → iOS app → GoogleService-Info.plist

  GoogleService-Info.plist is gitignored so real keys never end up in git.
  Bundle ID restriction in Firebase + App Check protects against misuse,
  but secret scanners (GitGuardian) still flag the key if committed.
-->
