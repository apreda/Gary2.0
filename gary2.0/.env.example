# Gary2.0 Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE (Required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# AI / LLM (Required)
# =============================================================================
# Google Gemini — primary LLM for pick generation & analysis
GEMINI_API_KEY=your-gemini-api-key
# Model overrides (optional — defaults are gemini-3-flash-preview / gemini-3-pro-preview)
# GEMINI_FLASH_MODEL=gemini-3-flash-preview
# GEMINI_PRO_MODEL=gemini-3-pro-preview
# GEMINI_PROXY_URL=                 # custom proxy URL (optional)

# =============================================================================
# SPORTS DATA APIs (Required)
# =============================================================================
# Ball Don't Lie — primary source for odds, stats, and player props
BALLDONTLIE_API_KEY=your-balldontlie-api-key

# =============================================================================
# DFS DATA (Optional)
# =============================================================================
# Tank01 RapidAPI — DFS salaries, projections
TANK01_RAPIDAPI_KEY=your-tank01-key
# Highlightly RapidAPI — alternative DFS data source
# HIGHLIGHTLY_RAPIDAPI_KEY=your-highlightly-key

# =============================================================================
# FIREBASE (Required for push notifications)
# =============================================================================
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com

# =============================================================================
# OPTIONAL APIs
# =============================================================================
# Quantum Random Number Generator (for quantum scores)
# QRNG_API_KEY=your-qrng-api-key

# =============================================================================
# VITE FRONTEND VARS (prefixed with VITE_ for browser access)
# =============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_BALLDONTLIE_API_KEY=your-balldontlie-api-key
# VITE_TANK01_RAPIDAPI_KEY=your-tank01-key
# VITE_HIGHLIGHTLY_RAPIDAPI_KEY=your-highlightly-key

# =============================================================================
# DEPLOYMENT (Vercel)
# =============================================================================
# VERCEL_URL=your-vercel-url
