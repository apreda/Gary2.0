# Gary2.0 Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# SUPABASE (Required)
# =============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# =============================================================================
# AI/LLM APIs (Required)
# =============================================================================
# Google Gemini (primary for pick generation)
GEMINI_API_KEY=your-gemini-api-key

# =============================================================================
# SPORTS DATA APIs (Required)
# =============================================================================
# The Odds API - for betting odds
ODDS_API_KEY=your-odds-api-key

# Ball Don't Lie API - for NBA/NFL stats
BALLDONTLIE_API_KEY=your-balldontlie-api-key

# =============================================================================
# OPTIONAL APIs
# =============================================================================
# Quantum Random Number Generator (for quantum scores)
QRNG_API_KEY=your-qrng-api-key

# Tank01 RapidAPI (for DFS data)
TANK01_RAPIDAPI_KEY=your-tank01-key

# =============================================================================
# DEPLOYMENT (Vercel)
# =============================================================================
# VERCEL_URL=your-vercel-url
# NEXT_PUBLIC_SITE_URL=https://your-site.com
